NODE_ENV=production
PORT=10000
DATABASE_PATH=/tmp/secureos-auth.db
JWT_SECRET=replace_with_64_plus_random_characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7
MFA_ENCRYPTION_KEY=replace_with_32_plus_random_characters
ADMIN_SEED_KEY=replace_with_seed_guard_secret
FRONTEND_URL=https://your-secureos-frontend.vercel.app
CORS_ORIGINS=https://your-secureos-frontend.vercel.app,https://*.vercel.app,http://localhost:3000,http://localhost:5173
REFRESH_COOKIE_SAMESITE=none
REFRESH_COOKIE_SECURE=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MAX_COMPLETION_TOKENS=4096
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SecureOS <no-reply@example.com>
